# Local dev / Expo Go: API base URL (no trailing slash). Use your PC's LAN IP so the device can reach the server.
# Example: http://192.168.0.101:5000  (replace with your machine's IP; port 5000 = local server)
# For production builds, set this via EAS secrets or app.json extra.serverUrl instead.
EXPO_PUBLIC_SERVER_URL=http://192.168.0.101:5000
