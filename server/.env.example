# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=rifah_shared
DB_HOST=localhost
DB_PORT=5434

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-at-least-32-characters-long

# Super Admin (required in production; min 12 chars, not a common weak password)
SUPERADMIN_PASSWORD=your-strong-superadmin-password-at-least-12-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@rifah.com
# Resend (for transactional emails: password reset, staff invite, etc.)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Rifah <noreply@rifah.sa>
# Deep link scheme for customer app password reset emails (default: refah)
CUSTOMER_APP_SCHEME=refah

# API Keys (optional)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Logging
LOG_LEVEL=info

# CORS (comma-separated). Production: set to your frontend origins (e.g. https://app.rifah.sa,https://admin.rifah.sa)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004

# ---------------------------------------------------------------------------
# PRODUCTION (VPS) - use these when NODE_ENV=production
# ---------------------------------------------------------------------------
# Full DB URL (required in production; overrides POSTGRES_* / DB_HOST / DB_PORT)
# DATABASE_URL=postgresql://user:password@host:5432/rifah_shared
# Optional: SSL for DB (set DB_SSL=true if your provider requires it)
# DB_SSL=false

# Public API base URL (emails, notifications, deep links). No trailing slash.
# BASE_URL=https://api.rifah.sa
# Or: API_URL=https://api.rifah.sa

# Redis (optional but recommended for booking locks; /ready returns 503 if Redis down)
# REDIS_URL=redis://localhost:6379
