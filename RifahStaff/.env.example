# Local dev / Expo Go: full API base URL (including /api/v1). Use your PC's LAN IP.
# Example: http://192.168.0.101:5000/api/v1  (replace with your machine's IP; port 5000 = local server)
# For production builds, set via EAS env or app.json extra.apiUrl.
EXPO_PUBLIC_API_URL=http://192.168.0.101:5000/api/v1
